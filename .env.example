# Copy to .env and fill in the client secret from the official task doc.
C8_AUTH_URL=https://auth.dev.digik.cantor8.tech/realms/master/protocol/openid-connect/token
C8_CLIENT_ID=hackathon
C8_CLIENT_SECRET=<client-secret-from-task-doc>
C8_VALIDATOR_API=https://api.validator.dev.digik.cantor8.tech/api/validator
C8_LEDGER_API=https://api.validator.dev.digik.cantor8.tech/api/ledger
# Used as both the ledger user name and the party id hint for the new internal party.
C8_PARTY_HINT=your-name-c8lab-1
